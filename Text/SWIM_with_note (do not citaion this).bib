@article{reardonShearShockWaves2023,
  title = {Shear Shock Waves Mediate Haptic Holography via Focused Ultrasound},
  author = {Reardon, Gregory and Dandu, Bharat and Shao, Yitian and Visell, Yon},
  date = {2023-03-03},
  journaltitle = {Science Advances},
  shortjournal = {Sci. Adv.},
  doi = {10.1126/sciadv.adf2037},
  langid = {english},
  note = {Paper Summary: This study investigates the mechanisms underlying the spatial resolution and dynamic range limitations of holographic haptic displays that use focused ultrasound to create tactile sensations in midair. Current systems produce diffuse and faint tactile feedback despite the fine acoustic focusing capabilities of ultrasound, with perceptual acuity far below theoretical predictions. The research demonstrates that ultrasound-driven elastic wave transport in soft tissues, particularly the formation of shear shock waves, significantly impacts the effective resolution of haptic feedback. Through numerical simulations, time-resolved optical imaging, and vibrometry experiments on both tissue phantoms and human hands, the authors show that rapidly scanning ultrasound focal points at transonic or supersonic speeds (relative to shear wave propagation speeds in skin) generates large-amplitude shear shock waves with spatial dimensions exceeding the acoustic focal area by more than an order of magnitude. These shock waves form Mach cones that trail the focal point, distributing energy over large surface areas (10--50 cm{$^2$}) compared to the focal area (0.28--0.36 cm{$^2$}), thereby reducing spatial resolution. Behavioral experiments revealed that perceptual accuracy declines monotonically with increasing wake length, dropping to chance levels at supersonic scanning speeds where shock waves are most pronounced. The study identifies that complex interference patterns arise when scanning trajectories change direction or display closed shapes, creating artifacts that further degrade haptic feedback quality. These findings provide a mechanistic explanation for the diffuse tactile sensations reported by users of current holographic haptic systems and suggest that techniques to mitigate or exploit shear shock phenomena are needed to improve the fidelity of midair haptic displays. The research highlights the critical role of viscoelastic wave transport in determining the perceptual characteristics of ultrasound-based haptic feedback and has important implications for the development of more effective holographic interfaces for virtual reality, teleoperation, and other applications.},
  file = {D:\Data\OneDrive\Library\Zotero Attachment\MAUH\ACH\Reardon et al. - 2023 - Shear shock waves mediate haptic holography via focused ultrasound 1.pdf}
}

@article{saalSimulatingTactileSignals2017,
  title = {Simulating Tactile Signals from the Whole Hand with Millisecond Precision},
  author = {Saal, Hannes P. and Delhaye, Benoit P. and Rayhaun, Brandon C. and Bensmaia, Sliman J.},
  date = {2017-07-11},
  journaltitle = {Proceedings of the National Academy of Sciences},
  shortjournal = {Proc. Natl. Acad. Sci. U.S.A.},
  doi = {10.1073/pnas.1704856114},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: This study by Saal et al. addresses the primitive state of understanding regarding population-level representations in tactile neuroscience despite extensive characterization of single-unit response properties. To bridge this gap, the authors developed a comprehensive computational model capable of simulating the responses of all tactile nerve fibers innervating the glabrous skin of the hand to any applied spatiotemporal stimulus with millisecond precision. The model operates through a two-stage mechanotransduction process wherein skin deformations are reconstructed using continuum mechanics to estimate stresses comprising a quasistatic component related to pressure redistribution and a dynamic component resulting from propagating surface waves; these mechanical inputs subsequently drive leaky integrate-and-fire spiking models fitted individually to afferent data, incorporating up to thirteen free parameters per fiber to account for heterogeneity within afferent classes. Validated against neurophysiological datasets from rhesus macaques and humans using sinusoidal, bandpass noise, and diharmonic vibrations, the model demonstrates high fidelity, matching measured firing rates with R-squared values exceeding 0.90 and achieving temporal precision better than 8 milliseconds, with Pacinian models reaching submillisecond accuracy, utilizing a van Rossum spike distance metric optimized via genetic algorithms to ensure accurate prediction without overfitting. Systematic comparisons confirm the model captures canonical biological properties including adaptation to ramp-and-hold indentations, hierarchical receptive field sizes where slowly adapting type I fibers possess the smallest fields and Pacinian fibers the largest, distinct frequency sensitivity profiles across afferent classes, and spatial interaction phenomena such as edge enhancement and surround suppression. Beyond single-unit validation, the researchers utilized the model to simulate entire populations of approximately 12,500 afferents distributed according to known innervation densities wherein RA fibers outnumber SA1 fibers by a factor of two and SA1 fibers outnumber PC fibers by a factor of two, revealing that most tactile experiences recruit multiple fiber populations simultaneously with spike counts varying over orders of magnitude depending on stimulus dynamics. Virtual experiments further elucidated population coding principles by simulating edge indentations at 32 orientations and texture scanning in 16 directions, demonstrating that edge orientation can be decoded from population spike counts within tens of milliseconds, largely relying on spatial activation patterns rather than precise spike timing, whereas decoding motion direction benefits significantly from analyzing correlated activity across adjacent neuron pairs using cross-correlograms. These findings suggest a cooperative interplay between submodalities where combined signals from different afferent populations provide more informative representations than any single group, challenging historical assumptions about specialized encoding channels. While acknowledging limitations such as the exclusion of slowly adapting type II fibers, the approximation of lateral sliding as frame-by-frame indentation, and the assumption of flat skin mechanics ignoring three-dimensional bulging, the authors argue the framework remains robust for investigating peripheral neural codes and psychophysical correlations. Finally, the paper highlights critical applications in neuroprosthetics, proposing that the model can convert outputs from prosthetic touch sensors into biomimetic afferent responses to drive electrical stimulation in residual nerves, thereby restoring naturalistic artificial touch, and underscores the model's computational efficiency which allows for real-time simulation essential for both basic somatosensory research and clinical interface development.},
  file = {D:\Data\OneDrive\Library\Zotero Attachment\SWIM\Saal et al. - 2017 - Simulating tactile signals from the whole hand with millisecond precision.pdf}
}

