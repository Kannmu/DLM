@article{johanssonTactileSensoryCoding1983,
  title = {Tactile Sensory Coding in the Glabrous Skin of the Human Hand},
  author = {Johansson, Roland S. and Vallbo, \AA ke B.},
  date = {1983-01},
  journaltitle = {Trends in Neurosciences},
  shortjournal = {Trends Neurosci.},
  doi = {10.1016/0166-2236(83)90011-5},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: The research paper presented by Johansson and Vallbo provides a comprehensive review of tactile sensory coding within the glabrous skin of the human hand, establishing the critical partnership between the human hand and the brain in exploring and reshaping the physical world through accurate mechanical descriptions. Utilizing the microneurographic technique introduced by Vallbo and Hagbarth, which involves percutaneously inserted tungsten microelectrodes to record impulses from single nerve fibres in awake human subjects, the authors were able to analyze tactile neural mechanisms with a precision previously available only in anesthetized animal experiments while simultaneously exploring the subject's psychophysical experience. The study focuses on the approximately 17,000 mechanoreceptive units innervating the hairless volar skin, which are classified into two major categories based on their response to sustained step indentation: slowly adapting units, which constitute about 44\% and respond with a sustained discharge, and fast-adapting units, comprising 56\% and responding with a burst of impulses only at stimulus onset and removal. Within these categories, four distinct types are distinguished by receptive field properties: the fast-adapting type I (FA I) and slow-adapting type I (SA I) units possess small, well-defined fields with sharp borders, whereas the fast-adapting type II (FA II) and slow-adapting type II (SA II) units exhibit wider fields with obscure boundaries. Anatomically, the end-organs corresponding to these units are identified as Meissner corpuscles for FA I units located in the papillary ridges, Merkel cell-neurite complexes for SA I units at the tip of intermediate epidermal ridges, Ruffini endings for SA II units in the dermis, and Pacinian corpuscles for FA II units in deeper skin layers and subcutaneous tissues. The functional specialization of these units is evident in their respective roles, where FA I and SA I units facilitate the extraction of spatial details and edge contours due to their high density and small receptive fields, particularly at the finger tips where density reaches 140 units cm\textasciicircum -2 for FA I and 70 units cm\textasciicircum -2 for SA I, correlating strongly with spatial discriminative capacity and psychophysical two-point discrimination thresholds. In contrast, the FA II and SA II units, with their low and relatively uniform density and large receptive fields, are not primarily involved in detailed spatial discrimination but instead encode temporal features such as vibrations between 100 Hz and 300 Hz for FA II units and lateral skin stretch for SA II units, the latter providing crucial information for evaluating shearing forces and controlling grip forces during manual manipulation. Furthermore, the study highlights that cutaneous mechanoreceptors contribute to proprioception and kinesthesia, as evidenced by the responsiveness of SA II and FA II units to joint movements and changes in skin tension patterns independent of direct touch, suggesting a role in motor control beyond simple exteroception. The correlation between neuronal activity and psychophysical phenomena reveals that detection thresholds for fine touch are set by peripheral mechanisms, specifically the sensitivity of FA I units, which often match psychophysical thresholds perfectly in high-acuity regions like the fingertip, whereas magnitude scaling suggests that subjective intensity grows faster than single-unit activity, implying significant contributions from central processing and unit recruitment. Finally, microstimulation studies demonstrate that electrically stimulating a single afferent fibre elicits sensations matching its functional class, such as light pressure for SA I units or buzzing and fluttery sensations for FA I units, thereby bridging the gap between biophysical events in the nervous system and mental events in the mind, ultimately supporting the view that the peripheral organization of mechanoreceptive units imposes fundamental constraints on human tactile perception and motor integration.},
  file = {D:\Data\OneDrive\Library\Zotero Attachment\SWIM\Johansson and Vallbo - 1983 - Tactile sensory coding in the glabrous skin of the human hand.pdf}
}

